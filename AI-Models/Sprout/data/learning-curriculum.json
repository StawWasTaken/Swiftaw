{
  "version": "1.0.0",
  "description": "Sprout Learning Curriculum — Toddler-to-Teen AI growth roadmap",
  "critical_rule": "Never skip stages. Sequential progression is mandatory. Skipping causes confused-but-confident behavior.",

  "stages": [
    {
      "id": 1,
      "name": "Toddler Brain",
      "range": "0 → 2,000 words",
      "focus": ["objects", "actions", "simple descriptors"],
      "capabilities": [
        "2-3 word combinations: 'dog run', 'big car', 'I eat'",
        "Basic object recognition and labeling",
        "Simple action-object pairing"
      ],
      "training_rules": {
        "max_sentence_length": 3,
        "grammar_enforcement": false,
        "word_types": ["nouns", "verbs", "basic adjectives"],
        "patterns": ["noun + verb", "adjective + noun", "pronoun + verb"]
      },
      "graduation_criteria": {
        "vocabulary_size": 2000,
        "accuracy_threshold": 0.80,
        "tests": [
          "Can label common objects correctly",
          "Can pair actions with objects",
          "Can use basic descriptors"
        ]
      }
    },
    {
      "id": 2,
      "name": "Child Language",
      "range": "2,000 → 8,000 words",
      "focus": ["pronouns", "connectors", "tense basics", "sentence structure"],
      "capabilities": [
        "Full simple sentences: 'The dog runs fast'",
        "Pronoun usage: 'I like this', 'She is happy'",
        "Basic tense awareness: present, past, future"
      ],
      "training_rules": {
        "max_sentence_length": 8,
        "grammar_enforcement": true,
        "word_types": ["nouns", "verbs", "adjectives", "pronouns", "articles", "prepositions"],
        "patterns": ["subject + verb + object", "adjective + noun + verb", "pronoun + verb + adjective"],
        "teach": ["Subject-Verb-Object order", "Adjective placement before nouns", "Article usage (a, an, the)"]
      },
      "graduation_criteria": {
        "vocabulary_size": 8000,
        "accuracy_threshold": 0.85,
        "tests": [
          "Can form grammatically correct simple sentences",
          "Uses pronouns correctly in context",
          "Demonstrates basic tense understanding",
          "Can answer simple who/what/where questions"
        ]
      }
    },
    {
      "id": 3,
      "name": "Pre-Teen Logic",
      "range": "8,000 → 20,000 words",
      "focus": ["abstract words", "multiple meanings", "cause and effect", "comparisons"],
      "capabilities": [
        "Complex sentences: 'I think this is good because it works'",
        "Understanding ambiguity and context",
        "Basic reasoning and explanation",
        "Comparison and contrast"
      ],
      "training_rules": {
        "max_sentence_length": 20,
        "grammar_enforcement": true,
        "word_types": ["all basic types", "adverbs", "conjunctions", "abstract nouns"],
        "patterns": [
          "compound sentences with conjunctions",
          "cause-effect with 'because/so/therefore'",
          "comparisons with 'more/less/better/worse'"
        ],
        "teach": [
          "Cause and effect relationships",
          "Word sense disambiguation",
          "Comparative and superlative forms",
          "Basic logical reasoning (if X then Y)"
        ]
      },
      "graduation_criteria": {
        "vocabulary_size": 20000,
        "accuracy_threshold": 0.85,
        "tests": [
          "Can explain why something happens",
          "Can handle words with multiple meanings",
          "Can make comparisons between concepts",
          "Can follow basic logical chains"
        ]
      }
    },
    {
      "id": 4,
      "name": "Teen Intelligence",
      "range": "20,000+ words",
      "focus": ["nuance", "tone", "domain knowledge", "structured reasoning"],
      "capabilities": [
        "Opinion forming and expression",
        "Structured explanations and arguments",
        "Style variation based on context",
        "Intent detection in user messages",
        "Domain-specific vocabulary (tech, social, science)"
      ],
      "training_rules": {
        "max_sentence_length": null,
        "grammar_enforcement": true,
        "word_types": ["all types", "domain-specific", "idiomatic expressions"],
        "patterns": [
          "argument structure (claim + evidence + conclusion)",
          "paragraph-level coherence",
          "tone adjustment (formal, casual, empathetic)"
        ],
        "teach": [
          "Argument structure and persuasion",
          "Style and tone variation",
          "Intent detection and response adaptation",
          "Multi-step reasoning",
          "Contextual appropriateness"
        ]
      },
      "graduation_criteria": {
        "vocabulary_size": null,
        "accuracy_threshold": 0.90,
        "tests": [
          "Can form and defend opinions with evidence",
          "Can adapt tone to different contexts",
          "Can detect user intent beyond literal meaning",
          "Can produce structured, coherent responses",
          "Can handle domain-specific conversations"
        ]
      }
    }
  ],

  "bilingual_extension": {
    "description": "French language module can be activated at any stage",
    "activation_rule": "Only activate after Stage 1 English graduation",
    "approach": "Cross-reference French words with known English equivalents",
    "dataset": "french-lexicon.json"
  }
}
