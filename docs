      </div>
    </div>

    <div id="create-step-form" style="display:none;">
      <h2>New Document</h2>
      <p class="modal-sub">Fill in the details below. The document will be published immediately.</p>
      <div class="form-group">
        <label>Title</label>
        <input type="text" id="doc-title" placeholder="Document title">
        <div class="error-msg" id="title-error">Please enter a title.</div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Project / Category</label>
          <input type="text" id="doc-project" placeholder="Project or "General"">
        </div>
        <div class="form-group">
          <label>Visibility</label>
          <select id="doc-visibility">
            <option value="public">Public</option>
            <option value="intern">Intern</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Author</label>
          <input type="text" id="doc-author" placeholder="Your name">
        </div>
        <div class="form-group">
          <label>Department</label>
          <input type="text" id="doc-dept" placeholder="Department or "Swiftaw Leadership"">
        </div>
      </div>
      <div class="form-group">
        <label>Subject</label>
        <input type="text" id="doc-subject" placeholder="Brief subject line">
      </div>
      <div class="form-group">
        <label>Body</label>
        <textarea id="doc-body" placeholder="Write the document content here..."></textarea>
        <div class="error-msg" id="body-error">Please write some content.</div>
      </div>
      <div class="modal-actions">
        <button class="btn-yellow" onclick="submitDocument()">Publish Document</button>
        <button class="btn-outline" onclick="closeCreateModal()">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- INTERN UNLOCK MODAL -->
<div class="modal-bg" id="intern-modal-bg">
  <div class="modal intern-unlock">
    <button class="modal-close" onclick="closeInternModal()">&times;</button>
    <h2>Intern Access</h2>
    <p class="modal-sub">Enter the intern password to unlock confidential documents.</p>
    <div class="form-group">
      <label>Password</label>
      <input type="password" id="intern-pw" placeholder="••••••" onkeydown="if(event.key==='Enter')checkInternPw()">
      <div class="error-msg" id="intern-pw-error">Incorrect password. Please try again.</div>
    </div>
    <div class="modal-actions">
      <button class="btn-dark" onclick="checkInternPw()">Unlock</button>
      <button class="btn-outline" onclick="closeInternModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- DOCUMENT VIEWER -->
<div class="doc-viewer" id="doc-viewer">
  <div class="doc-viewer-inner sw-doc-outer">
    <button class="dv-close" onclick="closeViewer()">&times;</button>
    <div class="sw-deco-left"></div>
    <div class="sw-deco-right"></div>
    <div class="sw-deco-bottom"></div>
    <div class="sw-deco-tl"></div>
    <div class="sw-deco-tr"></div>
    <div class="sw-doc" id="doc-content-inner">
      <!-- populated by JS -->
    </div>
  </div>
</div>

<script>
  const CREATE_PW = '1478';
  const INTERN_PW = 'SW1FT';
  let internUnlocked = false;
  let currentTab = 'all';

  const defaultDocs = [
    {
      id: 1,
      title: 'Fortized Platform Launch',
      project: 'Fortized',
      subject: 'Official public announcement of the Fortized gaming platform launch.',
      body: 'We are thrilled to announce the official launch of Fortized, our flagship gaming community platform.\n\nFortized brings together gamers, streamers, and communities in one unified space. Built on our latest AI infrastructure, the platform offers real-time chat, community hubs, leaderboards, and intelligent matchmaking.\n\nThis launch marks a major milestone for Swiftaw as we deliver on our mission to empower people through technology and connection.\n\nAll users can sign up at fortized.com starting today. We look forward to growing this community with you.',
      author: 'Swiftaw Leadership',
      dept: 'Swiftaw Leadership',
      date: 'March 2026',
      visibility: 'public'
    },
    {
      id: 2,
      title: 'R&D Roadmap Q2 2026',
      project: 'R&D',
      subject: 'Internal research and development priorities for Q2.',
      body: 'This document outlines the R&D department's strategic priorities for Q2 2026.\n\n1. Tithonia AI model improvements — focus on contextual memory and multi-turn reasoning.\n2. Social graph research — mapping connection patterns across Fortized communities.\n3. Safety systems — deployment of the next-generation content moderation pipeline.\n4. Infrastructure scaling — preparation for 10× user growth across all products.\n\nAll department leads are expected to review and confirm alignment by April 15. Budget allocations will follow in a separate memo.',
      author: 'R&D Team',
      dept: 'R&D',
      date: 'March 2026',
      visibility: 'intern'
    },
    {
      id: 3,
      title: 'Swiftaw Safety Commitments',
      project: 'Safety',
      subject: 'Public statement on Swiftaw's approach to platform safety.',
      body: 'Swiftaw is committed to building safe, trustworthy digital spaces for all users.\n\nOur safety principles:\n\n— Every product we build is reviewed by our Safety department before launch.\n— We invest in AI moderation tools that scale with our communities.\n— We maintain transparent reporting on safety incidents.\n— User feedback is central to how we improve our systems.\n\nSafety is not an afterthought at Swiftaw — it is embedded in our engineering culture from day one.',
      author: 'Safety Department',
      dept: 'Safety',
      date: 'February 2026',
      visibility: 'public'
    },
    {
      id: 4,
      title: 'Tithonia Internal Architecture',
      project: 'Tithonia',
      subject: 'Technical overview of the Tithonia AI platform internals.',
      body: 'This document is restricted to Swiftaw engineering and leadership.\n\nTithonia is built on a hybrid retrieval-augmented generation (RAG) architecture with a proprietary context window management layer. Key components:\n\n— Vector store: custom-built, optimized for sub-50ms retrieval at scale.\n— Model serving: multi-tenant inference cluster with dynamic load balancing.\n— Memory module: session-persistent and cross-session user preference graph.\n— Safety layer: real-time output filtering integrated at the token level.\n\nDetailed API documentation is available in the internal developer portal. Access requires two-factor authentication.',
      author: 'Engineering Team',
      dept: 'R&D',
      date: 'January 2026',
      visibility: 'intern'
    },
    {
      id: 5,
      title: 'Goals for the World — 2026 Edition',
      project: 'General',
      subject: 'Swiftaw's annual statement of mission and global objectives.',
      body: 'At Swiftaw, we believe technology should serve humanity — not the other way around.\n\nOur 2026 goals:\n\n1. Reach 1 million active users across all products by year-end.\n2. Publish three research papers on responsible AI development.\n3. Reduce platform carbon footprint by 30% through infrastructure optimisation.\n4. Launch an educational initiative to bring AI literacy to underserved communities.\n5. Open-source two internal tools to benefit the wider developer ecosystem.\n\nWe are accountable to these goals. Progress updates will be shared publicly each quarter.',
      author: 'Swiftaw Leadership',
      dept: 'Swiftaw Leadership',
      date: 'January 2026',
      visibility: 'public'
    }
  ];

  let documents = [...defaultDocs];

  function formatDate() {
    const now = new Date();
    return now.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
  }

  function renderDocs() {
    const grid = document.getElementById('doc-grid');
    const empty = document.getElementById('empty-state');
    const filtered = documents.filter(d => {
      if (currentTab === 'public') return d.visibility === 'public';
      if (currentTab === 'intern') return d.visibility === 'intern';
      return true;
    });

    grid.innerHTML = '';
    if (filtered.length === 0) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';

    filtered.forEach(doc => {
      const isLocked = doc.visibility === 'intern' && !internUnlocked;
      const card = document.createElement('div');
      card.className = 'doc-card';
      card.innerHTML = `
        <div class="doc-card-header">
          <div class="doc-card-icon">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <span class="badge badge-${doc.visibility}">${doc.visibility === 'intern' ? 'Intern' : 'Public'}</span>
        </div>
        <h3>${doc.title}</h3>
        <div class="doc-meta">${doc.project} &middot; ${doc.date}</div>
        <p>${doc.subject}</p>
        <div class="doc-card-footer">
          <span class="doc-card-author">${doc.author}</span>
          <span style="font-size:.8rem;font-weight:600;color:var(--brand-deep);">Read &rarr;</span>
        </div>
        ${isLocked ? `<div class="locked-overlay">
          <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span>Intern Access Required</span>
          <button class="btn-dark" style="padding:8px 18px;font-size:.82rem;margin-top:4px;" onclick="openInternModal()">Unlock</button>
        </div>` : ''}
      `;
      if (!isLocked) card.addEventListener('click', () => openViewer(doc.id));
      grid.appendChild(card);
    });
  }

  function switchTab(tab, btn) {
    currentTab = tab;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const eyebrow = document.getElementById('tab-eyebrow');
    eyebrow.textContent = tab === 'all' ? 'All Documents' : tab === 'public' ? 'Public Documents' : 'Intern Documents';
    renderDocs();
  }

  function openViewer(id) {
    const doc = documents.find(d => d.id === id);
    if (!doc) return;
    const inner = document.getElementById('doc-content-inner');
    inner.innerHTML = `
      <div class="sw-doc-logo-placeholder"><span>SW</span></div>
      <h1>${doc.title}</h1>
      <div class="sw-doc-subtitle">${doc.project}</div>
      <div class="sw-doc-subtitle">${doc.subject}</div>
      <div class="sw-doc-date">${doc.date}</div>
      <hr class="sw-doc-divider">
      <div class="sw-doc-body">${doc.body}</div>
      <div class="sw-doc-footer">
        <div class="author">${doc.author}</div>
        <div class="dept">${doc.dept}</div>
      </div>
    `;
    document.getElementById('doc-viewer').classList.add('open');
  }

  function closeViewer() {
    document.getElementById('doc-viewer').classList.remove('open');
  }

  /* CREATE FLOW */
  function openCreateModal() {
    document.getElementById('create-step-pw').style.display = 'block';
    document.getElementById('create-step-form').style.display = 'none';
    document.getElementById('create-pw').value = '';
    document.getElementById('create-pw-error').classList.remove('show');
    document.getElementById('create-modal-bg').classList.add('open');
    setTimeout(() => document.getElementById('create-pw').focus(), 100);
  }

  function closeCreateModal() {
    document.getElementById('create-modal-bg').classList.remove('open');
  }

  function checkCreatePw() {
    const val = document.getElementById('create-pw').value;
    if (val === CREATE_PW) {
      document.getElementById('create-step-pw').style.display = 'none';
      document.getElementById('create-step-form').style.display = 'block';
    } else {
      document.getElementById('create-pw-error').classList.add('show');
    }
  }

  function submitDocument() {
    const title = document.getElementById('doc-title').value.trim();
    const body = document.getElementById('doc-body').value.trim();
    let valid = true;
    if (!title) { document.getElementById('title-error').classList.add('show'); valid = false; }
    else { document.getElementById('title-error').classList.remove('show'); }
    if (!body) { document.getElementById('body-error').classList.add('show'); valid = false; }
    else { document.getElementById('body-error').classList.remove('show'); }
    if (!valid) return;

    const newDoc = {
      id: Date.now(),
      title,
      project: document.getElementById('doc-project').value.trim() || 'General',
      subject: document.getElementById('doc-subject').value.trim() || '',
      body,
      author: document.getElementById('doc-author').value.trim() || 'Swiftaw Team',
      dept: document.getElementById('doc-dept').value.trim() || 'Swiftaw',
      date: formatDate(),
      visibility: document.getElementById('doc-visibility').value
    };
    documents.unshift(newDoc);
    closeCreateModal();
    renderDocs();
    ['doc-title','doc-project','doc-subject','doc-author','doc-dept','doc-body'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('doc-visibility').value = 'public';
  }

  /* INTERN UNLOCK */
  function openInternModal() {
    document.getElementById('intern-pw').value = '';
    document.getElementById('intern-pw-error').classList.remove('show');
    document.getElementById('intern-modal-bg').classList.add('open');
    setTimeout(() => document.getElementById('intern-pw').focus(), 100);
  }

  function closeInternModal() {
    document.getElementById('intern-modal-bg').classList.remove('open');
  }

  function checkInternPw() {
    const val = document.getElementById('intern-pw').value;
    if (val === INTERN_PW) {
      internUnlocked = true;
      closeInternModal();
      renderDocs();
    } else {
      document.getElementById('intern-pw-error').classList.add('show');
    }
  }

  /* Close on backdrop click */
  document.getElementById('create-modal-bg').addEventListener('click', function(e) { if (e.target === this) closeCreateModal(); });
  document.getElementById('intern-modal-bg').addEventListener('click', function(e) { if (e.target === this) closeInternModal(); });
  document.getElementById('doc-viewer').addEventListener('click', function(e) { if (e.target === this) closeViewer(); });

  renderDocs();
</script>
</body>
</html>
