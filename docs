  <link rel="icon" type="image/png" href="/SwiftawFavicon.png">
  <link href="https://fonts.cdnfonts.com/css/afronaut-test" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-serif: 'Newsreader', Georgia, serif;
      --font-display: 'Afronaut Test', 'Newsreader', sans-serif;
      --brand-deep: #241f3c;
      --brand-yellow: #fff93e;
      --brand-orange: #ff9c3c;
      --bg: #ffffff;
      --text: #0a0a0a;
      --text-light: #555;
      --text-muted: #888;
      --border: #e5e5e5;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-sans); color: var(--text); background: var(--bg); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }

    /* NAV */
    .nav { position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; background: rgba(255,255,255,.72); backdrop-filter: blur(18px); border-bottom: 1px solid var(--border); }
    .nav-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; padding: 0 32px; height: 64px; gap: 8px; }
    .nav-logo { display: flex; align-items: center; gap: 10px; font-family: var(--font-serif); font-weight: 600; font-size: 1.18rem; color: var(--text); margin-right: 32px; white-space: nowrap; }
    .nav-logo img { height: 28px; width: auto; object-fit: contain; }
    .nav-logo-text { font-family: var(--font-serif); font-weight: 600; font-size: 1.1rem; }
    .nav-links { display: flex; align-items: center; gap: 4px; }
    .nav-link { font-size: .9rem; font-weight: 500; color: var(--text-light); padding: 8px 14px; border-radius: 8px; transition: color .2s, background .2s; cursor: pointer; white-space: nowrap; user-select: none; }
    .nav-link:hover { color: var(--text); background: rgba(0,0,0,.04); }
    .has-dropdown { display: flex; align-items: center; gap: 4px; }
    .caret { font-size: .55rem; opacity: .5; transition: transform .2s; }
    .nav-dropdown-wrap { position: relative; }
    .nav-dropdown-wrap:hover .nav-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
    .nav-dropdown-wrap:hover .caret { transform: rotate(180deg); }
    .nav-dropdown { position: absolute; top: calc(100% + 8px); left: 0; background: #fff; border: 1px solid var(--border); border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,.08); min-width: 220px; padding: 8px; opacity: 0; visibility: hidden; transform: translateY(6px); transition: opacity .2s, visibility .2s, transform .2s; }
    .nav-dropdown a { display: block; padding: 10px 14px; border-radius: 8px; font-size: .88rem; font-weight: 500; color: var(--text); transition: background .15s; }
    .nav-dropdown a:hover { background: rgba(0,0,0,.04); }
    .dd-desc { display: block; font-size: .78rem; font-weight: 400; color: var(--text-muted); margin-top: 2px; }
    .nav-spacer { flex: 1; }
    .nav-cta { background: var(--brand-yellow); color: var(--brand-deep); font-size: .88rem; font-weight: 600; padding: 9px 22px; border-radius: 100px; white-space: nowrap; transition: box-shadow .2s, transform .15s; }
    .nav-cta:hover { box-shadow: 0 0 32px rgba(255,249,62,.4); transform: translateY(-1px); }

    /* HERO */
    .hero { background: #faf8f3; padding: 180px 32px 80px; border-bottom: 1px solid var(--border); }
    .hero-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; align-items: start; }
    .hero-left h1 { font-family: var(--font-display); font-size: clamp(3rem, 6vw, 4.4rem); font-weight: 700; line-height: 1.05; color: var(--text); margin: 0 0 20px; }
    .highlight-bar { width: 64px; height: 3px; border-radius: 2px; background: linear-gradient(90deg, var(--brand-yellow), var(--brand-orange), var(--brand-deep)); }
    .hero-right { padding-top: 12px; }
    .hero-right p { font-family: var(--font-serif); font-size: 1.18rem; font-weight: 400; color: var(--text-light); line-height: 1.75; margin: 0 0 32px; }
    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

    /* BUTTONS */
    .btn-yellow { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-yellow); color: var(--brand-deep); font-size: .95rem; font-weight: 600; padding: 14px 28px; border-radius: 100px; border: none; cursor: pointer; transition: box-shadow .2s, transform .15s; font-family: var(--font-sans); }
    .btn-yellow:hover { box-shadow: 0 0 32px rgba(255,249,62,.4); transform: translateY(-1px); }
    .btn-dark { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-deep); color: #fff; font-size: .95rem; font-weight: 600; padding: 14px 28px; border-radius: 100px; border: none; cursor: pointer; transition: box-shadow .2s, transform .15s; font-family: var(--font-sans); }
    .btn-dark:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(36,31,60,.25); }
    .btn-outline { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--text); font-size: .95rem; font-weight: 600; padding: 14px 28px; border-radius: 100px; border: 1.5px solid var(--border); cursor: pointer; transition: border-color .2s, transform .15s; font-family: var(--font-sans); }
    .btn-outline:hover { border-color: var(--text-muted); transform: translateY(-1px); }

    /* SECTION */
    .section { padding: 80px 32px; max-width: 1200px; margin: 0 auto; }
    .divider { max-width: 1200px; margin: 0 auto; border: none; border-top: 1px solid var(--border); }

    /* TABS */
    .tabs-bar { display: flex; gap: 4px; margin-bottom: 40px; border-bottom: 1.5px solid var(--border); padding-bottom: 0; }
    .tab-btn { font-size: .92rem; font-weight: 600; padding: 10px 20px; background: none; border: none; cursor: pointer; color: var(--text-muted); border-bottom: 2.5px solid transparent; margin-bottom: -1.5px; transition: color .2s, border-color .2s; font-family: var(--font-sans); }
    .tab-btn.active { color: var(--brand-deep); border-bottom-color: var(--brand-deep); }
    .tab-btn:hover:not(.active) { color: var(--text); }

    /* BADGES */
    .badge { display: inline-block; font-size: .72rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; padding: 3px 10px; border-radius: 100px; }
    .badge-public { background: #e8f5e9; color: #2e7d32; }
    .badge-intern { background: #fff3e0; color: #bf5a00; }

    /* DOCUMENT CARDS */
    .doc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
    .doc-card { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 28px; transition: box-shadow .25s, transform .2s; cursor: pointer; position: relative; }
    .doc-card:hover { box-shadow: 0 8px 40px rgba(0,0,0,.07); transform: translateY(-3px); }
    .doc-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .doc-card-icon { width: 44px; height: 44px; border-radius: 12px; background: var(--brand-deep); display: flex; align-items: center; justify-content: center; }
    .doc-card-icon svg { width: 22px; height: 22px; stroke: var(--brand-yellow); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .doc-card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 6px; color: var(--text); }
    .doc-card .doc-meta { font-size: .82rem; color: var(--text-muted); margin-bottom: 10px; }
    .doc-card p { font-size: .9rem; color: var(--text-light); line-height: 1.6; }
    .doc-card-footer { margin-top: 18px; padding-top: 14px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .doc-card-author { font-size: .8rem; color: var(--text-muted); }
    .locked-overlay { position: absolute; inset: 0; background: rgba(255,255,255,.8); border-radius: 16px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; backdrop-filter: blur(2px); }
    .locked-overlay svg { width: 32px; height: 32px; stroke: var(--brand-deep); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .locked-overlay span { font-size: .88rem; font-weight: 600; color: var(--brand-deep); }

    /* EMPTY STATE */
    .empty-state { text-align: center; padding: 80px 20px; color: var(--text-muted); }
    .empty-state svg { width: 48px; height: 48px; stroke: var(--border); fill: none; stroke-width: 1.5; margin: 0 auto 16px; }
    .empty-state p { font-size: .95rem; }

    /* MODAL OVERLAY */
    .modal-bg { display: none; position: fixed; inset: 0; background: rgba(10,10,10,.45); z-index: 2000; align-items: center; justify-content: center; }
    .modal-bg.open { display: flex; }
    .modal { background: #fff; border-radius: 20px; padding: 44px 40px; max-width: 560px; width: calc(100% - 40px); box-shadow: 0 24px 80px rgba(0,0,0,.12); position: relative; max-height: 90vh; overflow-y: auto; }
    .modal-close { position: absolute; top: 18px; right: 20px; background: none; border: none; cursor: pointer; font-size: 1.4rem; color: var(--text-muted); line-height: 1; padding: 4px; }
    .modal-close:hover { color: var(--text); }
    .modal h2 { font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; margin-bottom: 8px; }
    .modal p.modal-sub { font-family: var(--font-serif); color: var(--text-light); margin-bottom: 28px; font-size: .96rem; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: .82rem; font-weight: 600; text-transform: uppercase; letter-spacing: .07em; color: var(--text-muted); margin-bottom: 7px; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; border: 1.5px solid var(--border); border-radius: 10px; padding: 11px 14px; font-size: .94rem; font-family: var(--font-sans); color: var(--text); background: #fff; outline: none; transition: border-color .2s; }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--brand-deep); }
    .form-group textarea { min-height: 100px; resize: vertical; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .error-msg { color: #c62828; font-size: .83rem; margin-top: 6px; display: none; }
    .error-msg.show { display: block; }
    .modal-actions { display: flex; gap: 12px; margin-top: 28px; }

    /* DOCUMENT VIEWER */
    .doc-viewer { display: none; position: fixed; inset: 0; background: rgba(10,10,10,.55); z-index: 3000; align-items: center; justify-content: center; }
    .doc-viewer.open { display: flex; }
    .doc-viewer-inner { background: #fff; border-radius: 20px; max-width: 680px; width: calc(100% - 40px); max-height: 90vh; overflow-y: auto; box-shadow: 0 24px 80px rgba(0,0,0,.15); position: relative; }
    .dv-close { position: absolute; top: 16px; right: 18px; background: none; border: none; cursor: pointer; font-size: 1.3rem; color: var(--text-muted); padding: 6px; z-index: 10; }
    .dv-close:hover { color: var(--text); }

    /* SWIFTAW DOCUMENT TEMPLATE */
    .sw-doc { padding: 44px 44px 40px; }
    .sw-doc-logo { width: 60px; margin-bottom: 32px; }
    .sw-doc-logo-placeholder { width: 60px; height: 60px; background: var(--brand-deep); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 32px; }
    .sw-doc-logo-placeholder span { color: var(--brand-yellow); font-weight: 700; font-size: .9rem; font-family: var(--font-display); }
    .sw-doc h1 { font-family: var(--font-sans); font-size: 2.4rem; font-weight: 800; line-height: 1.1; margin-bottom: 12px; }
    .sw-doc-subtitle { font-size: 1.05rem; color: var(--text-light); margin-bottom: 4px; }
    .sw-doc-date { font-size: 1.05rem; color: var(--text-light); margin-bottom: 24px; }
    .sw-doc-divider { border: none; border-top: 2px solid var(--text); margin-bottom: 28px; }
    .sw-doc-body { font-size: 1rem; color: var(--text); line-height: 1.8; white-space: pre-wrap; word-break: break-word; margin-bottom: 40px; }
    .sw-doc-footer { text-align: center; }
    .sw-doc-footer .author { font-size: 1rem; font-weight: 500; color: var(--text); }
    .sw-doc-footer .dept { font-size: .95rem; color: var(--text-light); }

    /* DOC FRAME DECORATIONS (like screenshot) */
    .sw-doc-outer { position: relative; overflow: hidden; }
    .sw-deco-left { position: absolute; left: -22px; top: 50%; transform: translateY(-50%); width: 52px; height: 70%; background: var(--brand-orange); border-radius: 0 30px 30px 0; opacity: .9; }
    .sw-deco-right { position: absolute; right: -22px; top: 50%; transform: translateY(-50%); width: 52px; height: 70%; background: var(--brand-orange); border-radius: 30px 0 0 30px; opacity: .9; }
    .sw-deco-bottom { position: absolute; bottom: -20px; left: 50%; transform: translateX(-50%); width: 120px; height: 44px; background: var(--brand-yellow); border-radius: 50% 50% 0 0; }
    .sw-deco-tl { position: absolute; top: 0; left: 0; width: 12px; height: 100%; background: var(--brand-deep); }
    .sw-deco-tr { position: absolute; top: 0; right: 0; width: 12px; height: 100%; background: var(--brand-deep); }

    /* INTERN UNLOCK MODAL */
    .intern-unlock { max-width: 400px; }

    /* SECTION HEADER */
    .section-eyebrow { font-size: .78rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--brand-orange); margin-bottom: 10px; }
    .section-title { font-family: var(--font-display); font-size: clamp(1.7rem, 3vw, 2.3rem); font-weight: 700; margin-bottom: 12px; }
    .section-lead { font-family: var(--font-serif); font-size: 1.05rem; color: var(--text-light); line-height: 1.7; margin-bottom: 32px; }

    /* FOOTER */
    footer { background: var(--bg); border-top: 1px solid var(--border); }
    .footer-inner { max-width: 1200px; margin: 0 auto; padding: 64px 32px 32px; }
    .footer-top { display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 56px; }
    .footer-brand p { font-size: .9rem; color: var(--text-muted); line-height: 1.65; margin-top: 16px; max-width: 280px; }
    .footer-col { display: flex; flex-direction: column; gap: 10px; }
    .footer-col-title { font-size: .78rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px; }
    .footer-col a { font-size: .9rem; color: var(--text-light); transition: color .15s; }
    .footer-col a:hover { color: var(--text); }
    .footer-bottom { display: flex; align-items: center; justify-content: space-between; padding-top: 28px; border-top: 1px solid var(--border); }
    .footer-copy { font-size: .82rem; color: var(--text-muted); }
    .footer-socials { display: flex; gap: 16px; }
    .footer-socials a { color: var(--text-muted); transition: color .15s; }
    .footer-socials a:hover { color: var(--text); }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero { padding: 120px 20px 60px; }
      .hero-inner { grid-template-columns: 1fr; gap: 28px; }
      .section { padding: 56px 20px; }
      .doc-grid { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
      .form-row { grid-template-columns: 1fr; }
      .modal { padding: 32px 24px; }
      .sw-doc { padding: 32px 28px 28px; }
      .sw-doc h1 { font-size: 1.8rem; }
    }
  </style>
</head>
